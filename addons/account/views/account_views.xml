<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="account_move_search">
      <field name="name">account.move search</field>
      <field name="model">account.move</field>
      <field name="arch" type="xml">
        <search>
          <field name="name"/>
          <field name="partner_id"/>
          <field name="invoice_origin"/>
          <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
          <filter name="posted" string="Posted" domain="[('state','=','posted')]"/>
        </search>
      </field>
    </record>
    <record model="ir.ui.view" id="account_move_list">
      <field name="name">account.move list</field>
      <field name="model">account.move</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="journal_id" comodel="account.journal"/>
          <field name="partner_id" comodel="res.partner"/>
          <field name="move_type"/>
          <field name="invoice_origin"/>
          <field name="state"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="account_move_form">
      <field name="name">account.move form</field>
      <field name="model">account.move</field>
      <field name="arch" type="xml">
        <form>
          <header>
            <button name="action_post" string="Post" type="object"/>
            <button name="action_cancel" string="Cancel" type="object"/>
          </header>
          <sheet>
            <field name="state" widget="statusbar"/>
            <field name="name"/>
            <field name="journal_id" comodel="account.journal"/>
            <field name="partner_id" comodel="res.partner"/>
            <field name="move_type"/>
            <field name="invoice_origin"/>
            <field name="line_ids">
              <list>
                <field name="account_id" comodel="account.account"/>
                <field name="name"/>
                <field name="debit"/>
                <field name="credit"/>
                <field name="partner_id" comodel="res.partner"/>
                <field name="analytic_account_id" comodel="analytic.account"/>
              </list>
            </field>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.ui.view" id="account_journal_list">
      <field name="name">account.journal list</field>
      <field name="model">account.journal</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="code"/>
          <field name="type"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="account_account_list">
      <field name="name">account.account list</field>
      <field name="model">account.account</field>
      <field name="arch" type="xml">
        <list>
          <field name="code"/>
          <field name="name"/>
          <field name="account_type"/>
        </list>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_account_move">
      <field name="name">Invoices</field>
      <field name="res_model">account.move</field>
      <field name="view_mode">list,form</field>
    </record>
    <record model="ir.actions.act_window" id="action_account_journal">
      <field name="name">Journals</field>
      <field name="res_model">account.journal</field>
      <field name="view_mode">list</field>
    </record>
    <record model="ir.actions.act_window" id="action_account_account">
      <field name="name">Chart of Accounts</field>
      <field name="res_model">account.account</field>
      <field name="view_mode">list</field>
    </record>
    <menuitem name="Invoicing" id="menu_account_root" sequence="11"/>
    <menuitem name="Invoices" id="menu_account_move" action="account.action_account_move" parent="account.menu_account_root" sequence="10"/>
    <menuitem name="Configuration" id="menu_account_config" sequence="20"/>
    <menuitem name="Journals" id="menu_account_journal" action="account.action_account_journal" parent="account.menu_account_config" sequence="10"/>
    <menuitem name="Chart of Accounts" id="menu_account_account" action="account.action_account_account" parent="account.menu_account_config" sequence="20"/>
    <record model="ir.ui.view" id="analytic_account_list">
      <field name="name">analytic.account list</field>
      <field name="model">analytic.account</field>
      <field name="arch" type="xml">
        <list>
          <field name="code"/>
          <field name="name"/>
          <field name="partner_id" comodel="res.partner"/>
          <field name="active"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="analytic_account_form">
      <field name="name">analytic.account form</field>
      <field name="model">analytic.account</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="code"/>
            <field name="partner_id" comodel="res.partner"/>
            <field name="active"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_analytic_account">
      <field name="name">Analytic Accounts</field>
      <field name="res_model">analytic.account</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Analytic Accounts" id="menu_analytic_account" action="account.action_analytic_account" parent="account.menu_account_config" sequence="30"/>
  </data>
</odoo>
