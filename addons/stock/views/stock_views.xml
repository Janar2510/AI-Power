<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="stock_picking_search">
      <field name="name">stock.picking search</field>
      <field name="model">stock.picking</field>
      <field name="arch" type="xml">
        <search>
          <field name="name"/>
          <field name="origin"/>
          <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
          <filter name="done" string="Done" domain="[('state','=','done')]"/>
        </search>
      </field>
    </record>
    <record model="ir.ui.view" id="stock_picking_list">
      <field name="name">stock.picking list</field>
      <field name="model">stock.picking</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="picking_type_id" comodel="stock.picking.type"/>
          <field name="partner_id" comodel="res.partner"/>
          <field name="origin"/>
          <field name="state"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="stock_picking_form">
      <field name="name">stock.picking form</field>
      <field name="model">stock.picking</field>
      <field name="arch" type="xml">
        <form>
          <header>
            <button name="action_confirm" string="Validate" type="object"/>
          </header>
          <sheet>
            <field name="name"/>
            <field name="picking_type_id" comodel="stock.picking.type"/>
            <field name="partner_id" comodel="res.partner"/>
            <field name="location_id" comodel="stock.location"/>
            <field name="location_dest_id" comodel="stock.location"/>
            <field name="origin"/>
            <field name="state"/>
            <field name="move_ids">
              <list>
                <field name="product_id" comodel="product.product"/>
                <field name="name"/>
                <field name="product_uom_qty"/>
                <field name="location_id" comodel="stock.location"/>
                <field name="location_dest_id" comodel="stock.location"/>
                <field name="state"/>
              </list>
            </field>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.ui.view" id="stock_warehouse_list">
      <field name="name">stock.warehouse list</field>
      <field name="model">stock.warehouse</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="code"/>
          <field name="lot_stock_id" comodel="stock.location"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="stock_warehouse_form">
      <field name="name">stock.warehouse form</field>
      <field name="model">stock.warehouse</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="code"/>
            <field name="lot_stock_id" comodel="stock.location"/>
            <field name="wh_output_stock_loc_id" comodel="stock.location"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_stock_picking">
      <field name="name">Transfers</field>
      <field name="res_model">stock.picking</field>
      <field name="view_mode">list,form</field>
    </record>
    <record model="ir.actions.act_window" id="action_stock_warehouse">
      <field name="name">Warehouses</field>
      <field name="res_model">stock.warehouse</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Inventory" id="menu_stock_root" sequence="12"/>
    <menuitem name="Operations" id="menu_stock_operations" sequence="10"/>
    <menuitem name="Transfers" id="menu_stock_picking" action="stock.action_stock_picking" parent="stock.menu_stock_operations" sequence="10"/>
    <menuitem name="Configuration" id="menu_stock_config" sequence="20"/>
    <menuitem name="Warehouses" id="menu_stock_warehouse" action="stock.action_stock_warehouse" parent="stock.menu_stock_config" sequence="10"/>
  </data>
</odoo>
