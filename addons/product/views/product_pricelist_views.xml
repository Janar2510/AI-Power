<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="product_pricelist_list">
      <field name="name">product.pricelist list</field>
      <field name="model">product.pricelist</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="currency_id" comodel="res.currency"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="product_pricelist_form">
      <field name="name">product.pricelist form</field>
      <field name="model">product.pricelist</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="currency_id" comodel="res.currency"/>
            <field name="item_ids">
              <list>
                <field name="product_id" comodel="product.product"/>
                <field name="min_qty"/>
                <field name="price_surcharge"/>
                <field name="percent_price"/>
                <field name="date_start"/>
                <field name="date_end"/>
              </list>
            </field>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_product_pricelist">
      <field name="name">Pricelists</field>
      <field name="res_model">product.pricelist</field>
      <field name="view_mode">list,form</field>
    </record>
  </data>
</odoo>
