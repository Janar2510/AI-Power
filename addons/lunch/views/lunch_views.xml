<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="lunch_order_list">
      <field name="name">lunch.order list</field>
      <field name="model">lunch.order</field>
      <field name="arch" type="xml">
        <list>
          <field name="user_id"/>
          <field name="product_id"/>
          <field name="date"/>
          <field name="price"/>
          <field name="state"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="lunch_order_form">
      <field name="name">lunch.order form</field>
      <field name="model">lunch.order</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="user_id"/>
            <field name="product_id"/>
            <field name="date"/>
            <field name="price"/>
            <field name="state"/>
            <field name="note"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_lunch_order">
      <field name="name">Lunch Orders</field>
      <field name="res_model">lunch.order</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Lunch" id="menu_lunch_root" sequence="41"/>
    <menuitem name="Orders" id="menu_lunch_order" parent="menu_lunch_root" action="action_lunch_order" sequence="1"/>
  </data>
</odoo>
