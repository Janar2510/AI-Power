<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    <record model="stock.location" id="stock_location_stock">
      <field name="name">Stock</field>
      <field name="type">internal</field>
    </record>
    <record model="stock.location" id="stock_location_output">
      <field name="name">Output</field>
      <field name="location_id" ref="stock_location_stock"/>
      <field name="type">internal</field>
    </record>
    <record model="stock.location" id="stock_location_supplier">
      <field name="name">Vendors</field>
      <field name="type">supplier</field>
    </record>
    <record model="stock.location" id="stock_location_customer">
      <field name="name">Customers</field>
      <field name="type">customer</field>
    </record>
    <record model="stock.warehouse" id="stock_warehouse_main">
      <field name="name">Main Warehouse</field>
      <field name="code">WH</field>
      <field name="lot_stock_id" ref="stock_location_stock"/>
      <field name="wh_output_stock_loc_id" ref="stock_location_output"/>
    </record>
    <record model="stock.picking.type" id="stock_picking_type_out">
      <field name="name">Delivery Orders</field>
      <field name="code">outgoing</field>
      <field name="warehouse_id" ref="stock_warehouse_main"/>
      <field name="default_location_src_id" ref="stock_location_stock"/>
      <field name="default_location_dest_id" ref="stock_location_customer"/>
    </record>
    <record model="stock.picking.type" id="stock_picking_type_in">
      <field name="name">Receipts</field>
      <field name="code">incoming</field>
      <field name="warehouse_id" ref="stock_warehouse_main"/>
      <field name="default_location_src_id" ref="stock_location_supplier"/>
      <field name="default_location_dest_id" ref="stock_location_stock"/>
    </record>
  </data>
</odoo>
