<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="slide_channel_list">
      <field name="name">slide.channel list</field>
      <field name="model">slide.channel</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="enroll"/>
          <field name="website_published"/>
          <field name="total_slides"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="slide_channel_form">
      <field name="name">slide.channel form</field>
      <field name="model">slide.channel</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="enroll"/>
            <field name="website_published"/>
            <field name="total_slides"/>
            <field name="total_time"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_slide_channel">
      <field name="name">eLearning</field>
      <field name="res_model">slide.channel</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="eLearning" id="menu_website_slides_root" sequence="46"/>
    <menuitem name="Courses" id="menu_website_slide_channel" parent="menu_website_slides_root" action="action_slide_channel" sequence="1"/>
  </data>
</odoo>
