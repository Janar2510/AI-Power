<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="event_event_list">
      <field name="name">event.event list</field>
      <field name="model">event.event</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="date_begin"/>
          <field name="date_end"/>
          <field name="state"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="event_registration_list">
      <field name="name">event.registration list</field>
      <field name="model">event.registration</field>
      <field name="arch" type="xml">
        <list>
          <field name="event_id" comodel="event.event"/>
          <field name="partner_id" comodel="res.partner"/>
          <field name="email"/>
          <field name="state"/>
        </list>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_event_event">
      <field name="name">Events</field>
      <field name="res_model">event.event</field>
      <field name="view_mode">list,form</field>
    </record>
    <record model="ir.actions.act_window" id="action_event_registration">
      <field name="name">Registrations</field>
      <field name="res_model">event.registration</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Events" id="menu_event_root" sequence="80"/>
    <menuitem name="Events" id="menu_event_event" action="action_event_event" parent="menu_event_root" sequence="10"/>
    <menuitem name="Registrations" id="menu_event_registration" action="action_event_registration" parent="menu_event_root" sequence="20"/>
  </data>
</odoo>
