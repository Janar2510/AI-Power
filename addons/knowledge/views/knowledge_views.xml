<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="knowledge_category_search">
      <field name="name">knowledge.category search</field>
      <field name="model">knowledge.category</field>
      <field name="arch" type="xml">
        <search>
          <field name="name"/>
        </search>
      </field>
    </record>
    <record model="ir.ui.view" id="knowledge_category_list">
      <field name="name">knowledge.category list</field>
      <field name="model">knowledge.category</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="parent_id" comodel="knowledge.category"/>
          <field name="sequence"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="knowledge_category_form">
      <field name="name">knowledge.category form</field>
      <field name="model">knowledge.category</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="parent_id" comodel="knowledge.category"/>
            <field name="sequence"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.ui.view" id="knowledge_article_search">
      <field name="name">knowledge.article search</field>
      <field name="model">knowledge.article</field>
      <field name="arch" type="xml">
        <search>
          <field name="name"/>
          <field name="body_html"/>
          <filter name="published" string="Published" domain="[('is_published','=',True)]"/>
        </search>
      </field>
    </record>
    <record model="ir.ui.view" id="knowledge_article_list">
      <field name="name">knowledge.article list</field>
      <field name="model">knowledge.article</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="category_id" comodel="knowledge.category"/>
          <field name="author_id" comodel="res.users"/>
          <field name="is_published"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="knowledge_article_form">
      <field name="name">knowledge.article form</field>
      <field name="model">knowledge.article</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="category_id" comodel="knowledge.category"/>
            <field name="author_id" comodel="res.users"/>
            <field name="is_published"/>
            <field name="body_html"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_knowledge_article">
      <field name="name">Articles</field>
      <field name="res_model">knowledge.article</field>
      <field name="view_mode">list,form</field>
    </record>
    <record model="ir.actions.act_window" id="action_knowledge_category">
      <field name="name">Categories</field>
      <field name="res_model">knowledge.category</field>
      <field name="view_mode">list,form</field>
    </record>
    <record model="ir.ui.menu" id="menu_knowledge_root">
      <field name="name">Knowledge</field>
      <field name="sequence">35</field>
    </record>
    <record model="ir.ui.menu" id="menu_knowledge_articles">
      <field name="name">Articles</field>
      <field name="action" ref="action_knowledge_article"/>
      <field name="parent_id" ref="menu_knowledge_root"/>
      <field name="sequence">10</field>
    </record>
    <record model="ir.ui.menu" id="menu_knowledge_categories">
      <field name="name">Categories</field>
      <field name="action" ref="action_knowledge_category"/>
      <field name="parent_id" ref="menu_knowledge_root"/>
      <field name="sequence">20</field>
    </record>
  </data>
</odoo>
