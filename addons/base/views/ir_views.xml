<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="res_partner_list">
      <field name="name">res.partner list</field>
      <field name="model">res.partner</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="email"/>
          <field name="phone"/>
          <field name="city"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="res_partner_form">
      <field name="name">res.partner form</field>
      <field name="model">res.partner</field>
      <field name="arch" type="xml">
        <form>
          <field name="name"/>
          <field name="email"/>
          <field name="phone"/>
          <field name="street"/>
          <field name="city"/>
          <field name="country"/>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_partner">
      <field name="name">Contacts</field>
      <field name="res_model">res.partner</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Home" id="menu_home" sequence="10"/>
    <menuitem name="Contacts" id="menu_contacts" action="base.action_partner" sequence="20"/>
  </data>
</odoo>
