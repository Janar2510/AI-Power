<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="stock_picking_search">
      <field name="name">stock.picking search</field>
      <field name="model">stock.picking</field>
      <field name="arch" type="xml">
        <search>
          <field name="name"/>
          <field name="origin"/>
          <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
          <filter name="done" string="Done" domain="[('state','=','done')]"/>
        </search>
      </field>
    </record>
    <record model="ir.ui.view" id="stock_picking_list">
      <field name="name">stock.picking list</field>
      <field name="model">stock.picking</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="picking_type_id" comodel="stock.picking.type"/>
          <field name="partner_id" comodel="res.partner"/>
          <field name="origin"/>
          <field name="state"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="stock_picking_form">
      <field name="name">stock.picking form</field>
      <field name="model">stock.picking</field>
      <field name="arch" type="xml">
        <form>
          <header>
            <button name="action_confirm" string="Validate" type="object"/>
          </header>
          <sheet>
            <field name="name"/>
            <field name="picking_type_id" comodel="stock.picking.type"/>
            <field name="partner_id" comodel="res.partner"/>
            <field name="location_id" comodel="stock.location"/>
            <field name="location_dest_id" comodel="stock.location"/>
            <field name="origin"/>
            <field name="state"/>
            <field name="move_ids">
              <list>
                <field name="product_id" comodel="product.product"/>
                <field name="name"/>
                <field name="product_uom_qty"/>
                <field name="lot_id" comodel="stock.lot"/>
                <field name="location_id" comodel="stock.location"/>
                <field name="location_dest_id" comodel="stock.location"/>
                <field name="state"/>
              </list>
            </field>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.ui.view" id="stock_warehouse_list">
      <field name="name">stock.warehouse list</field>
      <field name="model">stock.warehouse</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="code"/>
          <field name="lot_stock_id" comodel="stock.location"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="stock_warehouse_form">
      <field name="name">stock.warehouse form</field>
      <field name="model">stock.warehouse</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="code"/>
            <field name="lot_stock_id" comodel="stock.location"/>
            <field name="wh_output_stock_loc_id" comodel="stock.location"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_stock_picking">
      <field name="name">Transfers</field>
      <field name="res_model">stock.picking</field>
      <field name="view_mode">list,form</field>
    </record>
    <record model="ir.actions.act_window" id="action_stock_warehouse">
      <field name="name">Warehouses</field>
      <field name="res_model">stock.warehouse</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Inventory" id="menu_stock_root" sequence="12"/>
    <menuitem name="Operations" id="menu_stock_operations" parent="stock.menu_stock_root" sequence="10"/>
    <menuitem name="Transfers" id="menu_stock_picking" action="stock.action_stock_picking" parent="stock.menu_stock_operations" sequence="10"/>
    <menuitem name="Configuration" id="menu_stock_config" parent="stock.menu_stock_root" sequence="20"/>
    <menuitem name="Warehouses" id="menu_stock_warehouse" action="stock.action_stock_warehouse" parent="stock.menu_stock_config" sequence="10"/>
    <record model="ir.ui.view" id="stock_warehouse_orderpoint_list">
      <field name="name">stock.warehouse.orderpoint list</field>
      <field name="model">stock.warehouse.orderpoint</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="product_id" comodel="product.product"/>
          <field name="location_id" comodel="stock.location"/>
          <field name="product_min_qty"/>
          <field name="product_max_qty"/>
          <field name="qty_multiple"/>
          <field name="partner_id" comodel="res.partner"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="stock_warehouse_orderpoint_form">
      <field name="name">stock.warehouse.orderpoint form</field>
      <field name="model">stock.warehouse.orderpoint</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="product_id" comodel="product.product"/>
            <field name="location_id" comodel="stock.location"/>
            <field name="product_min_qty"/>
            <field name="product_max_qty"/>
            <field name="qty_multiple"/>
            <field name="partner_id" comodel="res.partner"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_stock_warehouse_orderpoint">
      <field name="name">Reordering Rules</field>
      <field name="res_model">stock.warehouse.orderpoint</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Reordering Rules" id="menu_stock_orderpoint" action="stock.action_stock_warehouse_orderpoint" parent="stock.menu_stock_config" sequence="15"/>
    <record model="ir.ui.view" id="stock_valuation_layer_list">
      <field name="name">stock.valuation.layer list</field>
      <field name="model">stock.valuation.layer</field>
      <field name="arch" type="xml">
        <list>
          <field name="product_id" comodel="product.product"/>
          <field name="quantity"/>
          <field name="unit_cost"/>
          <field name="value"/>
          <field name="stock_move_id" comodel="stock.move"/>
          <field name="description"/>
          <field name="create_date"/>
        </list>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_stock_valuation_layer">
      <field name="name">Valuation</field>
      <field name="res_model">stock.valuation.layer</field>
      <field name="view_mode">list</field>
    </record>
    <menuitem name="Reporting" id="menu_stock_reporting" parent="stock.menu_stock_root" sequence="15"/>
    <menuitem name="Valuation" id="menu_stock_valuation" action="stock.action_stock_valuation_layer" parent="stock.menu_stock_reporting" sequence="10"/>
    <record model="ir.actions.act_url" id="action_stock_valuation_report">
      <field name="name">Stock Valuation Report</field>
      <field name="url">#reports/stock-valuation</field>
      <field name="target">self</field>
    </record>
    <menuitem name="Stock Valuation Report" id="menu_stock_valuation_report" action="stock.action_stock_valuation_report" parent="stock.menu_stock_reporting" sequence="15"/>
    <record model="ir.ui.view" id="stock_lot_search">
      <field name="name">stock.lot search</field>
      <field name="model">stock.lot</field>
      <field name="arch" type="xml">
        <search>
          <field name="name"/>
          <field name="product_id"/>
        </search>
      </field>
    </record>
    <record model="ir.ui.view" id="stock_lot_list">
      <field name="name">stock.lot list</field>
      <field name="model">stock.lot</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="product_id" comodel="product.product"/>
          <field name="company_id" comodel="res.company"/>
          <field name="expiry_date"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="stock_lot_form">
      <field name="name">stock.lot form</field>
      <field name="model">stock.lot</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="product_id" comodel="product.product"/>
            <field name="company_id" comodel="res.company"/>
            <field name="expiry_date"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_stock_lot">
      <field name="name">Lots</field>
      <field name="res_model">stock.lot</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Lots" id="menu_stock_lot" action="stock.action_stock_lot" parent="stock.menu_stock_config" sequence="5"/>
  </data>
</odoo>
