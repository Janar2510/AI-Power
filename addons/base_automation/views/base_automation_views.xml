<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="base_automation_list">
      <field name="name">base.automation list</field>
      <field name="model">base.automation</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="model_name"/>
          <field name="trigger"/>
          <field name="action_type"/>
          <field name="active"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="base_automation_form">
      <field name="name">base.automation form</field>
      <field name="model">base.automation</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="model_name"/>
              <field name="trigger"/>
              <field name="interval_minutes" invisible="trigger != 'on_time'"/>
              <field name="active"/>
            </group>
            <group string="Filter">
              <field name="filter_domain" placeholder="[['state','=','draft']]"/>
            </group>
            <group string="Action">
              <field name="action_type"/>
              <field name="action_server_id" invisible="action_type != 'server_action'"/>
              <field name="update_vals" invisible="action_type != 'update'" placeholder='{"state": "done"}'/>
              <field name="webhook_url" invisible="action_type != 'webhook'"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_base_automation">
      <field name="name">Automated Actions</field>
      <field name="res_model">base.automation</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Automated Actions" id="menu_base_automation" action="base_automation.action_base_automation" parent="base.menu_technical" sequence="18"/>
  </data>
</odoo>
