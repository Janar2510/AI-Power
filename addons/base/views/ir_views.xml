<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="res_partner_search">
      <field name="name">res.partner search</field>
      <field name="model">res.partner</field>
      <field name="arch" type="xml">
        <search>
          <field name="name"/>
          <field name="email"/>
          <field name="phone"/>
        </search>
      </field>
    </record>
    <record model="ir.ui.view" id="res_partner_list">
      <field name="name">res.partner list</field>
      <field name="model">res.partner</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="is_company"/>
          <field name="email"/>
          <field name="phone"/>
          <field name="city"/>
          <field name="country_id" comodel="res.country"/>
          <field name="state_id" comodel="res.country.state"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="res_partner_form">
      <field name="name">res.partner form</field>
      <field name="model">res.partner</field>
      <field name="arch" type="xml">
        <form>
          <header/>
          <sheet>
          <group string="Contact">
            <field name="name"/>
            <field name="is_company"/>
            <field name="type"/>
            <field name="email"/>
            <field name="phone"/>
          </group>
          <notebook>
            <page string="Address">
              <field name="street"/>
              <field name="street2"/>
              <field name="city"/>
              <field name="zip"/>
              <field name="country_id" comodel="res.country"/>
              <field name="state_id" comodel="res.country.state" domain="[('country_id','=',country_id)]" domain_dep="country_id"/>
            </page>
          </notebook>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_partner">
      <field name="name">Contacts</field>
      <field name="res_model">res.partner</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Home" id="menu_home" sequence="10"/>
    <menuitem name="Contacts" id="menu_contacts" action="base.action_partner" sequence="20"/>
    <menuitem name="Settings" id="menu_settings" sequence="40"/>
    <menuitem name="API Keys" id="menu_settings_apikeys" parent="base.menu_settings" sequence="10"/>
    <record model="ir.ui.view" id="res_users_list">
      <field name="name">res.users list</field>
      <field name="model">res.users</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="login"/>
          <field name="active"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="res_users_form">
      <field name="name">res.users form</field>
      <field name="model">res.users</field>
      <field name="arch" type="xml">
        <form>
          <header/>
          <sheet>
            <group string="User">
              <field name="name"/>
              <field name="login"/>
              <field name="active"/>
              <field name="group_ids" comodel="res.groups"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_res_users">
      <field name="name">Users</field>
      <field name="res_model">res.users</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Users" id="menu_settings_users" parent="base.menu_settings" action="base.action_res_users" sequence="15"/>
    <record model="ir.ui.view" id="ir_attachment_list">
      <field name="name">ir.attachment list</field>
      <field name="model">ir.attachment</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="res_model"/>
          <field name="res_id"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="ir_attachment_form">
      <field name="name">ir.attachment form</field>
      <field name="model">ir.attachment</field>
      <field name="arch" type="xml">
        <form>
          <field name="name"/>
          <field name="res_model"/>
          <field name="res_id"/>
          <field name="datas" widget="binary"/>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_ir_attachment">
      <field name="name">Attachments</field>
      <field name="res_model">ir.attachment</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Attachments" id="menu_attachments" action="base.action_ir_attachment" parent="base.menu_settings" sequence="5"/>
  </data>
</odoo>
