<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="hr_applicant_list">
      <field name="name">hr.applicant list</field>
      <field name="model">hr.applicant</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="email"/>
          <field name="job_id" comodel="hr.job"/>
          <field name="stage_id" comodel="hr.recruitment.stage"/>
          <field name="kanban_state"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="hr_applicant_form">
      <field name="name">hr.applicant form</field>
      <field name="model">hr.applicant</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="email"/>
            <field name="phone"/>
            <field name="job_id" comodel="hr.job"/>
            <field name="stage_id" comodel="hr.recruitment.stage"/>
            <field name="partner_id" comodel="res.partner"/>
            <field name="kanban_state"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.ui.view" id="hr_recruitment_stage_list">
      <field name="name">hr.recruitment.stage list</field>
      <field name="model">hr.recruitment.stage</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="sequence"/>
        </list>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_hr_applicant">
      <field name="name">Applicants</field>
      <field name="res_model">hr.applicant</field>
      <field name="view_mode">list,form</field>
    </record>
    <record model="ir.actions.act_window" id="action_hr_recruitment_stage">
      <field name="name">Recruitment Stages</field>
      <field name="res_model">hr.recruitment.stage</field>
      <field name="view_mode">list</field>
    </record>
    <menuitem name="Applicants" id="menu_hr_applicant" action="action_hr_applicant" parent="hr.menu_hr_root" sequence="25"/>
    <menuitem name="Recruitment Stages" id="menu_hr_recruitment_stage" action="action_hr_recruitment_stage" parent="hr.menu_hr_root" sequence="26"/>
  </data>
</odoo>
