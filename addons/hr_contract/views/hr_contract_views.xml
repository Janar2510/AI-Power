<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="hr_contract_list">
      <field name="name">hr.contract list</field>
      <field name="model">hr.contract</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="employee_id" comodel="hr.employee"/>
          <field name="wage"/>
          <field name="date_start"/>
          <field name="date_end"/>
          <field name="state"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="hr_contract_form">
      <field name="name">hr.contract form</field>
      <field name="model">hr.contract</field>
      <field name="arch" type="xml">
        <form>
          <header>
            <button name="action_open_contract" string="Start Contract" type="object" invisible="state != 'draft'"/>
          </header>
          <sheet>
            <field name="name"/>
            <field name="employee_id" comodel="hr.employee"/>
            <field name="wage"/>
            <field name="date_start"/>
            <field name="date_end"/>
            <field name="state"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_hr_contract">
      <field name="name">Contracts</field>
      <field name="res_model">hr.contract</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Contracts" id="menu_hr_contract" action="action_hr_contract" parent="hr.menu_hr_root" sequence="35"/>
    <record model="ir.ui.view" id="hr_employee_form_contract" inherit_id="hr.hr_employee_form">
      <field name="name">hr.employee form (contract)</field>
      <field name="model">hr.employee</field>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='lifecycle_status']" position="after">
          <field name="contract_id" comodel="hr.contract" readonly="1"/>
        </xpath>
      </field>
    </record>
  </data>
</odoo>
