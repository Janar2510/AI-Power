<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="hr_expense_list">
      <field name="name">hr.expense list</field>
      <field name="model">hr.expense</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="employee_id"/>
          <field name="product_id"/>
          <field name="unit_amount"/>
          <field name="quantity"/>
          <field name="total_amount"/>
          <field name="date"/>
          <field name="state"/>
          <field name="sheet_id"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="hr_expense_form">
      <field name="name">hr.expense form</field>
      <field name="model">hr.expense</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="employee_id"/>
            <field name="product_id"/>
            <field name="unit_amount"/>
            <field name="quantity"/>
            <field name="total_amount"/>
            <field name="date"/>
            <field name="analytic_account_id" comodel="analytic.account"/>
            <field name="state"/>
            <field name="sheet_id"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.ui.view" id="hr_expense_sheet_list">
      <field name="name">hr.expense.sheet list</field>
      <field name="model">hr.expense.sheet</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="employee_id"/>
          <field name="total_amount"/>
          <field name="state"/>
          <field name="account_move_id"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="hr_expense_sheet_form">
      <field name="name">hr.expense.sheet form</field>
      <field name="model">hr.expense.sheet</field>
      <field name="arch" type="xml">
        <form>
          <header>
            <button name="action_submit" string="Submit" type="object" invisible="state != 'draft'"/>
            <button name="action_approve" string="Approve" type="object" invisible="state != 'submit'"/>
            <button name="action_done" string="Post" type="object" invisible="state != 'approve'"/>
            <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done', 'cancel')"/>
          </header>
          <sheet>
            <field name="name"/>
            <field name="employee_id"/>
            <field name="total_amount"/>
            <field name="state"/>
            <field name="journal_id"/>
            <field name="account_move_id"/>
            <field name="expense_line_ids">
              <list>
                <field name="name"/>
                <field name="product_id"/>
                <field name="unit_amount"/>
                <field name="quantity"/>
                <field name="total_amount"/>
                <field name="date"/>
                <field name="analytic_account_id" comodel="analytic.account"/>
                <field name="state"/>
              </list>
            </field>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_hr_expense">
      <field name="name">Expenses</field>
      <field name="res_model">hr.expense</field>
      <field name="view_mode">list,form</field>
    </record>
    <record model="ir.actions.act_window" id="action_hr_expense_sheet">
      <field name="name">Expense Reports</field>
      <field name="res_model">hr.expense.sheet</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Expenses" id="menu_hr_expense_root" sequence="24"/>
    <menuitem name="My Expenses" id="menu_hr_expense_my_expenses" action="action_hr_expense" parent="menu_hr_expense_root" sequence="1"/>
    <menuitem name="Reporting" id="menu_hr_expense_reports" action="action_hr_expense_sheet" parent="menu_hr_expense_root" sequence="2"/>
  </data>
</odoo>
