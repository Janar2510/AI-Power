<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="crm_lead_search">
      <field name="name">crm.lead search</field>
      <field name="model">crm.lead</field>
      <field name="arch" type="xml">
        <search>
          <searchpanel>
            <field name="stage_id" select="one"/>
          </searchpanel>
          <field name="name"/>
          <field name="description"/>
          <filter name="opportunities" string="Opportunities" domain="[('type','=','opportunity')]"/>
          <filter name="leads" string="Leads" domain="[('type','=','lead')]"/>
          <filter name="group_stage" string="Stage" context="{'group_by': 'stage_id'}"/>
        </search>
      </field>
    </record>
    <record model="ir.ui.view" id="crm_lead_list">
      <field name="name">crm.lead list</field>
      <field name="model">crm.lead</field>
      <field name="arch" type="xml">
        <list editable="bottom">
          <field name="name"/>
          <field name="type"/>
          <field name="stage_id" comodel="crm.stage"/>
          <field name="ai_score_label" string="AI"/>
          <field name="date_deadline"/>
          <field name="expected_revenue"/>
          <field name="tag_ids" comodel="crm.tag" widget="many2many_tags"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="crm_lead_form">
      <field name="name">crm.lead form</field>
      <field name="model">crm.lead</field>
      <field name="arch" type="xml">
        <form>
          <header>
            <field name="stage_id" comodel="crm.stage" widget="statusbar"/>
            <button name="action_mark_won" string="Mark Won" type="object"/>
          </header>
          <sheet>
            <field name="name"/>
            <field name="type"/>
            <field name="partner_id" comodel="res.partner"/>
            <field name="user_id" comodel="res.users"/>
            <field name="ai_score" readonly="1"/>
            <field name="ai_score_label" readonly="1"/>
            <field name="currency_id" comodel="res.currency" invisible="[('type','=','lead')]"/>
            <field name="expected_revenue" invisible="[('type','=','lead')]"/>
            <field name="description"/>
            <field name="note_html"/>
          <field name="tag_ids" comodel="crm.tag" widget="many2many_tags"/>
          <field name="date_deadline"/>
          <field name="activity_ids"/>
          <field name="message_ids"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.ui.view" id="crm_lead_kanban">
      <field name="name">crm.lead kanban</field>
      <field name="model">crm.lead</field>
      <field name="arch" type="xml">
        <kanban default_group_by="stage_id">
          <field name="name"/>
          <field name="stage_id"/>
          <field name="ai_score_label"/>
          <field name="priority" widget="priority"/>
          <field name="expected_revenue"/>
          <templates>
            <t t-name="kanban-box">
              <div class="oe_kanban_card"><field name="name"/><field name="ai_score_label"/><field name="expected_revenue"/></div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>
    <record model="ir.ui.view" id="crm_lead_calendar">
      <field name="name">crm.lead calendar</field>
      <field name="model">crm.lead</field>
      <field name="arch" type="xml">
        <calendar date_start="date_deadline" string="name"/>
      </field>
    </record>
    <record model="ir.ui.view" id="crm_lead_graph">
      <field name="name">crm.lead graph</field>
      <field name="model">crm.lead</field>
      <field name="arch" type="xml">
        <graph type="bar">
          <field name="stage_id" type="row" comodel="crm.stage"/>
          <field name="expected_revenue" type="measure"/>
        </graph>
      </field>
    </record>
    <record model="ir.ui.view" id="crm_lead_activity">
      <field name="name">crm.lead activity</field>
      <field name="model">crm.lead</field>
      <field name="arch" type="xml">
        <activity string="Activities" date_deadline="date_deadline">
          <field name="activity_ids"/>
        </activity>
      </field>
    </record>
    <record model="ir.ui.view" id="crm_lead_pivot">
      <field name="name">crm.lead pivot</field>
      <field name="model">crm.lead</field>
      <field name="arch" type="xml">
        <pivot>
          <field name="stage_id" type="row" comodel="crm.stage"/>
          <field name="type" type="col"/>
          <field name="expected_revenue" type="measure"/>
        </pivot>
      </field>
    </record>
    <record model="ir.ui.view" id="crm_stage_list">
      <field name="name">crm.stage list</field>
      <field name="model">crm.stage</field>
      <field name="arch" type="xml">
        <list>
          <field name="sequence"/>
          <field name="name"/>
          <field name="fold"/>
          <field name="is_won"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="crm_stage_form">
      <field name="name">crm.stage form</field>
      <field name="model">crm.stage</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="sequence"/>
            <field name="fold"/>
            <field name="is_won"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.ui.view" id="crm_tag_list">
      <field name="name">crm.tag list</field>
      <field name="model">crm.tag</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="crm_tag_form">
      <field name="name">crm.tag form</field>
      <field name="model">crm.tag</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.ui.view" id="crm_lost_reason_list">
      <field name="name">crm.lost.reason list</field>
      <field name="model">crm.lost.reason</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="crm_lost_reason_form">
      <field name="name">crm.lost.reason form</field>
      <field name="model">crm.lost.reason</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_crm_stage">
      <field name="name">Stages</field>
      <field name="res_model">crm.stage</field>
      <field name="view_mode">list,form</field>
    </record>
    <record model="ir.actions.act_window" id="action_crm_tag">
      <field name="name">Tags</field>
      <field name="res_model">crm.tag</field>
      <field name="view_mode">list,form</field>
    </record>
    <record model="ir.actions.act_window" id="action_crm_lost_reason">
      <field name="name">Lost Reasons</field>
      <field name="res_model">crm.lost.reason</field>
      <field name="view_mode">list,form</field>
    </record>
    <record model="ir.actions.act_window" id="action_crm_lead">
      <field name="name">Leads</field>
      <field name="res_model">crm.lead</field>
      <field name="view_mode">activity,kanban,list,graph,pivot,calendar,form</field>
    </record>
    <record model="ir.actions.act_window" id="action_crm_pipeline">
      <field name="name">My Pipeline</field>
      <field name="res_model">crm.lead</field>
      <field name="domain">[('type','=','opportunity')]</field>
      <field name="view_mode">kanban,list,activity,graph,pivot,calendar,form</field>
    </record>
    <record model="ir.actions.act_window" id="action_crm_activity_leads">
      <field name="name">My Activities</field>
      <field name="res_model">crm.lead</field>
      <field name="view_mode">activity,kanban,list,graph,pivot,calendar,form</field>
    </record>

    <menuitem name="CRM" id="crm_menu_root" sequence="30"/>
    <menuitem name="Sales" id="crm_menu_sales" parent="crm_menu_root" sequence="1"/>
    <menuitem name="My Pipeline" id="menu_crm_opportunities" parent="crm_menu_sales" action="action_crm_pipeline" sequence="1"/>
    <menuitem name="My Activities" id="crm_menu_my_activities" parent="crm_menu_sales" action="action_crm_activity_leads" sequence="2"/>
    <menuitem name="Customers" id="crm_menu_customers" parent="crm_menu_sales" action="base.action_partner_form" sequence="3"/>

    <menuitem name="Leads" id="menu_crm_lead" parent="crm_menu_root" action="action_crm_lead" sequence="5"/>

    <menuitem name="Reporting" id="crm_menu_report" parent="crm_menu_root" sequence="20"/>
    <menuitem name="Pipeline" id="crm_menu_report_pipeline" parent="crm_menu_report" action="action_crm_pipeline" sequence="1"/>
    <menuitem name="Activities" id="crm_menu_report_activities" parent="crm_menu_report" action="action_crm_activity_leads" sequence="2"/>

    <menuitem name="Configuration" id="crm_menu_config" parent="crm_menu_root" sequence="25"/>
    <menuitem name="Stages" id="menu_crm_stage_config" parent="crm_menu_config" action="action_crm_stage" sequence="1"/>
    <menuitem name="Tags" id="menu_crm_tag_config" parent="crm_menu_config" action="action_crm_tag" sequence="2"/>
    <menuitem name="Lost Reasons" id="menu_crm_lost_reason_config" parent="crm_menu_config" action="action_crm_lost_reason" sequence="3"/>
  </data>
</odoo>
