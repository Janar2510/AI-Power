<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="crm_lead_list">
      <field name="name">crm.lead list</field>
      <field name="model">crm.lead</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="type"/>
          <field name="stage_id"/>
          <field name="expected_revenue"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="crm_lead_form">
      <field name="name">crm.lead form</field>
      <field name="model">crm.lead</field>
      <field name="arch" type="xml">
        <form>
          <field name="name"/>
          <field name="type"/>
          <field name="partner_id"/>
          <field name="stage_id"/>
          <field name="expected_revenue"/>
          <field name="description"/>
          <field name="activity_ids"/>
        </form>
      </field>
    </record>
    <record model="ir.ui.view" id="crm_lead_kanban">
      <field name="name">crm.lead kanban</field>
      <field name="model">crm.lead</field>
      <field name="arch" type="xml">
        <kanban default_group_by="stage_id">
          <field name="name"/>
          <field name="stage_id"/>
          <field name="expected_revenue"/>
          <templates>
            <t t-name="kanban-box">
              <div class="oe_kanban_card"><field name="name"/><field name="expected_revenue"/></div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_crm_lead">
      <field name="name">Leads</field>
      <field name="res_model">crm.lead</field>
      <field name="view_mode">kanban,list,form</field>
    </record>
    <menuitem name="Leads" id="menu_crm_lead" action="action_crm_lead" sequence="30"/>
  </data>
</odoo>
