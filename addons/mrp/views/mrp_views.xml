<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="mrp_bom_list">
      <field name="name">mrp.bom list</field>
      <field name="model">mrp.bom</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="product_id" comodel="product.product"/>
          <field name="product_qty"/>
          <field name="type"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="mrp_bom_form">
      <field name="name">mrp.bom form</field>
      <field name="model">mrp.bom</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="product_id" comodel="product.product"/>
            <field name="product_qty"/>
            <field name="type"/>
            <field name="bom_line_ids">
              <list>
                <field name="product_id" comodel="product.product"/>
                <field name="product_qty"/>
              </list>
            </field>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.ui.view" id="mrp_production_list">
      <field name="name">mrp.production list</field>
      <field name="model">mrp.production</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="product_id" comodel="product.product"/>
          <field name="product_qty"/>
          <field name="state"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="mrp_production_form">
      <field name="name">mrp.production form</field>
      <field name="model">mrp.production</field>
      <field name="arch" type="xml">
        <form>
          <header>
            <button name="action_confirm" string="Confirm" type="object" invisible="state != 'draft'"/>
            <button name="action_start" string="Start" type="object" invisible="state != 'confirmed'"/>
            <button name="action_done" string="Done" type="object" invisible="state != 'progress'"/>
            <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done', 'cancel')"/>
          </header>
          <sheet>
            <field name="name"/>
            <field name="product_id" comodel="product.product"/>
            <field name="bom_id" comodel="mrp.bom"/>
            <field name="product_qty"/>
            <field name="state"/>
            <field name="move_ids">
              <list>
                <field name="product_id" comodel="product.product"/>
                <field name="product_uom_qty"/>
                <field name="location_id" comodel="stock.location"/>
                <field name="location_dest_id" comodel="stock.location"/>
                <field name="state"/>
              </list>
            </field>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.ui.view" id="mrp_workcenter_list">
      <field name="name">mrp.workcenter list</field>
      <field name="model">mrp.workcenter</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="capacity"/>
          <field name="time_start"/>
          <field name="time_stop"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="mrp_workcenter_form">
      <field name="name">mrp.workcenter form</field>
      <field name="model">mrp.workcenter</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="capacity"/>
            <field name="time_start"/>
            <field name="time_stop"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_mrp_production">
      <field name="name">Manufacturing Orders</field>
      <field name="res_model">mrp.production</field>
      <field name="view_mode">list,form</field>
    </record>
    <record model="ir.actions.act_window" id="action_mrp_bom">
      <field name="name">Bills of Materials</field>
      <field name="res_model">mrp.bom</field>
      <field name="view_mode">list,form</field>
    </record>
    <record model="ir.actions.act_window" id="action_mrp_workcenter">
      <field name="name">Work Centers</field>
      <field name="res_model">mrp.workcenter</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Manufacturing" id="menu_mrp_root" sequence="35"/>
    <menuitem name="Orders" id="menu_mrp_production" parent="mrp.menu_mrp_root" action="mrp.action_mrp_production" sequence="10"/>
    <menuitem name="Bills of Materials" id="menu_mrp_bom" parent="mrp.menu_mrp_root" action="mrp.action_mrp_bom" sequence="20"/>
    <menuitem name="Work Centers" id="menu_mrp_workcenter" parent="mrp.menu_mrp_root" action="mrp.action_mrp_workcenter" sequence="30"/>
  </data>
</odoo>
