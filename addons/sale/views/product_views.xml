<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="product_attribute_list">
      <field name="name">product.attribute list</field>
      <field name="model">product.attribute</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="product_attribute_value_list">
      <field name="name">product.attribute.value list</field>
      <field name="model">product.attribute.value</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="attribute_id"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="product_template_list">
      <field name="name">product.template list</field>
      <field name="model">product.template</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="list_price"/>
          <field name="categ_id"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="product_template_form">
      <field name="name">product.template form</field>
      <field name="model">product.template</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="list_price"/>
            <field name="categ_id"/>
            <field name="attribute_line_ids" widget="one2many">
              <list>
                <field name="attribute_id"/>
                <field name="value_ids" widget="many2many_tags"/>
              </list>
            </field>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.ui.view" id="product_product_list">
      <field name="name">product.product list</field>
      <field name="model">product.product</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="list_price"/>
          <field name="product_template_id"/>
          <field name="attribute_value_ids" widget="many2many_tags"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="product_product_form">
      <field name="name">product.product form</field>
      <field name="model">product.product</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="product_template_id"/>
            <field name="name"/>
            <field name="list_price"/>
            <field name="attribute_value_ids" widget="many2many_tags"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_product_product">
      <field name="name">Products</field>
      <field name="res_model">product.product</field>
      <field name="view_mode">list,form</field>
    </record>
    <record model="ir.actions.act_window" id="action_product_template">
      <field name="name">Product Templates</field>
      <field name="res_model">product.template</field>
      <field name="view_mode">list,form</field>
    </record>
    <record model="ir.actions.act_window" id="action_product_attribute">
      <field name="name">Attributes</field>
      <field name="res_model">product.attribute</field>
      <field name="view_mode">list</field>
    </record>
  </data>
</odoo>
