<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="res_partner_search">
      <field name="name">res.partner search</field>
      <field name="model">res.partner</field>
      <field name="arch" type="xml">
        <search>
          <field name="name"/>
          <field name="email"/>
          <field name="phone"/>
        </search>
      </field>
    </record>
    <record model="ir.ui.view" id="res_partner_list">
      <field name="name">res.partner list</field>
      <field name="model">res.partner</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="is_company"/>
          <field name="email"/>
          <field name="phone"/>
          <field name="city"/>
          <field name="country_id" comodel="res.country"/>
          <field name="state_id" comodel="res.country.state"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="res_partner_form">
      <field name="name">res.partner form</field>
      <field name="model">res.partner</field>
      <field name="arch" type="xml">
        <form>
          <header/>
          <sheet>
          <group string="Contact">
            <field name="name"/>
            <field name="is_company"/>
            <field name="type"/>
            <field name="email"/>
            <field name="phone"/>
          </group>
          <notebook>
            <page string="Address">
              <field name="street"/>
              <field name="street2"/>
              <field name="city"/>
              <field name="zip"/>
              <field name="country_id" comodel="res.country"/>
              <field name="state_id" comodel="res.country.state" domain="[('country_id','=',country_id)]" domain_dep="country_id"/>
            </page>
          </notebook>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_partner">
      <field name="name">Contacts</field>
      <field name="res_model">res.partner</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Home" id="menu_home" sequence="10"/>
    <menuitem name="Contacts" id="menu_contacts" action="base.action_partner" sequence="20"/>
    <menuitem name="Settings" id="menu_settings" sequence="40"/>
    <menuitem name="API Keys" id="menu_settings_apikeys" parent="base.menu_settings" sequence="10"/>
    <record model="ir.ui.view" id="res_users_list">
      <field name="name">res.users list</field>
      <field name="model">res.users</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="login"/>
          <field name="active"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="res_users_form">
      <field name="name">res.users form</field>
      <field name="model">res.users</field>
      <field name="arch" type="xml">
        <form>
          <header/>
          <sheet>
            <group string="User">
              <field name="name"/>
              <field name="login"/>
              <field name="active"/>
              <field name="group_ids" comodel="res.groups"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_res_users">
      <field name="name">Users</field>
      <field name="res_model">res.users</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Users" id="menu_settings_users" parent="base.menu_settings" action="base.action_res_users" sequence="15"/>
    <record model="ir.ui.view" id="ir_attachment_list">
      <field name="name">ir.attachment list</field>
      <field name="model">ir.attachment</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="res_model"/>
          <field name="res_id"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="ir_attachment_form">
      <field name="name">ir.attachment form</field>
      <field name="model">ir.attachment</field>
      <field name="arch" type="xml">
        <form>
          <field name="name"/>
          <field name="res_model"/>
          <field name="res_id"/>
          <field name="datas" widget="binary"/>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_ir_attachment">
      <field name="name">Attachments</field>
      <field name="res_model">ir.attachment</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Attachments" id="menu_attachments" action="base.action_ir_attachment" parent="base.menu_settings" sequence="5"/>
    <record model="ir.ui.view" id="ir_actions_server_form">
      <field name="name">ir.actions.server form</field>
      <field name="model">ir.actions.server</field>
      <field name="arch" type="xml">
        <form>
          <field name="name"/>
          <field name="state"/>
          <field name="code" placeholder="env, record, records in scope"/>
        </form>
      </field>
    </record>
    <record model="ir.ui.view" id="base_automation_list">
      <field name="name">base.automation list</field>
      <field name="model">base.automation</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="model_name"/>
          <field name="trigger"/>
          <field name="active"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="base_automation_form">
      <field name="name">base.automation form</field>
      <field name="model">base.automation</field>
      <field name="arch" type="xml">
        <form>
          <field name="name"/>
          <field name="model_name"/>
          <field name="trigger"/>
          <field name="filter_domain" placeholder="[['field','=','value']]"/>
          <field name="action_server_id" comodel="ir.actions.server"/>
          <field name="active"/>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_base_automation">
      <field name="name">Automated Actions</field>
      <field name="res_model">base.automation</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Automated Actions" id="menu_base_automation" action="base.action_base_automation" parent="base.menu_settings" sequence="20"/>
    <menuitem name="Technical" id="menu_technical" parent="base.menu_settings" sequence="50"/>
    <record model="ir.ui.view" id="ir_cron_list">
      <field name="name">ir.cron list</field>
      <field name="model">ir.cron</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="model"/>
          <field name="method"/>
          <field name="interval_minutes"/>
          <field name="next_run"/>
          <field name="active"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="ir_cron_form">
      <field name="name">ir.cron form</field>
      <field name="model">ir.cron</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="model"/>
            <field name="method"/>
            <field name="interval_minutes"/>
            <field name="next_run"/>
            <field name="active"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_ir_cron">
      <field name="name">Scheduled Actions</field>
      <field name="res_model">ir.cron</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Scheduled Actions" id="menu_ir_cron" action="base.action_ir_cron" parent="base.menu_technical" sequence="10"/>
    <record model="ir.ui.view" id="ir_actions_server_list">
      <field name="name">ir.actions.server list</field>
      <field name="model">ir.actions.server</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="state"/>
        </list>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_ir_actions_server">
      <field name="name">Server Actions</field>
      <field name="res_model">ir.actions.server</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Server Actions" id="menu_ir_actions_server" action="base.action_ir_actions_server" parent="base.menu_technical" sequence="20"/>
    <record model="ir.ui.view" id="ir_sequence_list">
      <field name="name">ir.sequence list</field>
      <field name="model">ir.sequence</field>
      <field name="arch" type="xml">
        <list>
          <field name="code"/>
          <field name="name"/>
          <field name="number_next"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="ir_sequence_form">
      <field name="name">ir.sequence form</field>
      <field name="model">ir.sequence</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="code"/>
            <field name="name"/>
            <field name="number_next"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_ir_sequence">
      <field name="name">Sequences</field>
      <field name="res_model">ir.sequence</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Sequences" id="menu_ir_sequence" action="base.action_ir_sequence" parent="base.menu_technical" sequence="30"/>
    <record model="ir.ui.view" id="approval_rule_list">
      <field name="name">approval.rule list</field>
      <field name="model">approval.rule</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="model"/>
          <field name="field_trigger"/>
          <field name="approver_user_id" comodel="res.users"/>
          <field name="approver_group_id" comodel="res.groups"/>
          <field name="sequence"/>
          <field name="active"/>
        </list>
      </field>
    </record>
    <record model="ir.ui.view" id="approval_rule_form">
      <field name="name">approval.rule form</field>
      <field name="model">approval.rule</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="name"/>
            <field name="model"/>
            <field name="field_trigger"/>
            <field name="approver_user_id" comodel="res.users"/>
            <field name="approver_group_id" comodel="res.groups"/>
            <field name="sequence"/>
            <field name="min_amount"/>
            <field name="amount_field"/>
            <field name="active"/>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_approval_rule">
      <field name="name">Approval Rules</field>
      <field name="res_model">approval.rule</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem name="Approval Rules" id="menu_approval_rule" action="base.action_approval_rule" parent="base.menu_settings" sequence="15"/>
    <record model="ir.ui.view" id="approval_request_list">
      <field name="name">approval.request list</field>
      <field name="model">approval.request</field>
      <field name="arch" type="xml">
        <list>
          <field name="rule_id" comodel="approval.rule"/>
          <field name="res_model"/>
          <field name="res_id"/>
          <field name="state"/>
          <field name="requested_value"/>
          <field name="approver_id" comodel="res.users"/>
          <field name="create_date"/>
        </list>
      </field>
    </record>
    <record model="ir.actions.act_window" id="action_approval_request">
      <field name="name">Approval Requests</field>
      <field name="res_model">approval.request</field>
      <field name="view_mode">list</field>
      <field name="domain">[('state','=','pending')]</field>
    </record>
    <menuitem name="Approval Requests" id="menu_approval_request" action="base.action_approval_request" parent="base.menu_settings" sequence="16"/>
  </data>
</odoo>
